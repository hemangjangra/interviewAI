# InterviewAI Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ============================================================
# DATABASE
# ============================================================
# PostgreSQL connection string
# Example: postgresql://user:password@localhost:5432/interview_ai
DATABASE_URL="postgresql://postgres:password@localhost:5432/interview_ai"

# ============================================================
# NEXTAUTH / AUTH.JS
# ============================================================
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"

# Your application URL (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ============================================================
# GOOGLE OAUTH (optional but recommended)
# ============================================================
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ============================================================
# AI PROVIDER
# ============================================================
# Set to: "gemini" | "openai" | "anthropic" | "mock"
# Use "mock" for development without an API key
AI_PROVIDER="mock"

# Google Gemini
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# OpenAI (alternative)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# Anthropic (alternative)
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# ============================================================
# FILE STORAGE (for resume uploads)
# ============================================================
# For local development, files are stored in /uploads
# For production, configure a cloud storage provider
# UPLOAD_PROVIDER="local" | "s3" | "cloudinary"
UPLOAD_PROVIDER="local"

# AWS S3 (optional, for production)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="ap-south-1"
# AWS_S3_BUCKET=""

# ============================================================
# RATE LIMITING (optional)
# ============================================================
# Requests per minute per user for AI endpoints
AI_RATE_LIMIT_RPM="10"

# ============================================================
# NODE ENVIRONMENT
# ============================================================
NODE_ENV="development"
